# General
APP_NAME=iMaritime API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Comma-separated list of allowed frontend origins (React dev server, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# DB (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=imaritime
POSTGRES_PASSWORD=imaritime
POSTGRES_DB=imaritime

# File storage
UPLOAD_STORAGE_DIR=./uploads
MAX_UPLOAD_BYTES=52428800

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=reports
SEMANTIC_SIMILARITY_THRESHOLD=0.55
QDRANT_DOCKER_IMAGE=qdrant/qdrant
QDRANT_CONTAINER_NAME=imaritime-qdrant

# Embeddings (used for semantic search)
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL_NAME=BAAI/bge-small-en-v1.5
FASTEMBED_VECTOR_SIZE=384
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_VECTOR_SIZE=1536
OPENAI_API_KEY=
SEMANTIC_SEARCH_TIMEOUT_SECONDS=8.0


STORE_FULL_REPORT_TEXT=true

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_TIME_LIMIT=900
JOB_STALE_AFTER_SECONDS=1800

# LLM
MODEL=openai/gpt-4o-mini
API_BASE=https://api.openai.com/v1
API_KEY=

# DSPy
DSPY_LM_MAX_RETRIES=12
DSPY_NUM_THREADS=8
DSPY_BATCH_TIMEOUT_SECONDS=300
DSPY_ADAPTER=json

# MLflow
MLFLOW_EXPERIMENT_NAME=imaritime
MLFLOW_TRACKING_URI=
MLFLOW_LOG_TRACES=true
MLFLOW_LOG_TRACES_FROM_COMPILE=true
MLFLOW_LOG_TRACES_FROM_EVAL=true
MLFLOW_LOG_COMPILES=true
MLFLOW_LOG_EVALS=true

# Intelligence briefs
MAX_REPORTS_PER_BRIEF=10